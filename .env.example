# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# Local SQLite is used when DATABASE_URL is empty.
# Railway/Postgres example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# Nebius OpenAI-compatible API
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1
NEBIUS_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# REST API key (required for /api/v1 endpoints)
COMMS_API_KEY=change-me
